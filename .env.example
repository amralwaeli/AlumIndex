# AlumIndex — environment variables
# Copy to .env and fill in real values. Never commit .env to version control.

# OpenAI (LLM normalisation only — no scraping)
OPENAI_API_KEY=sk-...

# Supabase / PostgreSQL
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_KEY=<anon-or-service-role-key>
# prepareThreshold=0 is required when connecting through a transaction pooler
# (e.g. Supabase :6543) — server-side prepared statements break behind pgbouncer
DB_URL=jdbc:postgresql://<host>:5432/<db>?prepareThreshold=0
DB_USERNAME=postgres
DB_PASSWORD=<password>

# JWT signing secret (HS256, min 32 chars)
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# Mail (for invite + approval emails) — sent via Resend's HTTPS API, not SMTP.
# Create a key at https://resend.com (API Keys) and verify your sending domain
# (Domains) so MAIL_FROM can be an address on that domain.
MAIL_FROM=no-reply@alumindex.org
MAIL_FROM_NAME=AlumIndex
RESEND_API_KEY=<resend-api-key>

# Backend
BACKEND_PORT=8080
FRONTEND_ORIGIN=http://localhost:5173

# Frontend (Vite build-time — prefix with VITE_)
VITE_API_BASE_URL=http://localhost:8080
